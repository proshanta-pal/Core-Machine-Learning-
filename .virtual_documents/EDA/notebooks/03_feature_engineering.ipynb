print("Survival Rate (%) by Pclass and Sex")
print(pivot)

# Create a single string label, combining both, so that the model can learn the specific survival rate for each combination independently
X_train['Pclass_Sex'] = X_train['Pclass'].astype(str) + '_' + X_train['Sex'].astype(str)
X_test['Pclass_Sex'] = X_test['Pclass'].astype(str) + '_' + X_test['Sex'].astype(str)

# Look at the unique combinations and their survival rates
print("Pclass_Sex combinations and survival rates:")
interaction_survival = (pd.concat([X_train['Pclass_Sex'], y_train], axis=1).groupby('Pclass_Sex')['Survived'].agg(['mean', 'count']).round(3).sort_values('mean', ascending=False))
interaction_survival


X_train.head()


# One-hot encode the interaction feature
interaction_train = pd.get_dummies(X_train['Pclass_Sex'], prefix='PS', drop_first=True)
interaction_test = pd.get_dummies(X_test['Pclass_Sex'], prefix='PS', drop_first=True)

# Align columns 
interaction_test = interaction_test.reindex(columns= interaction_train.columns, fill_value = 0)

X_train = pd.concat([X_train, interaction_train], axis=1)
X_tesr = pd.concat([X_test, interaction_test], axis=1)

print("Interaction feature columns added:")
print([c for c in X_train.columns if c.startswith('PS')])


# Final Feature Engineering Summary

print("Final Feature Engineering Summary")
print(f"Training set: {X_train.shape}")
print(f"Test set shape: {X_test.shape}", end='\n\n')
print("All columns in final dataset:")
for i, col in enumerate(X_train.columns, 1):
    print(f"{i}. {col}")
    
print()
print("Any missing values?")
missing = X_train.isnull().sum().sum()
print(f"{'None - clean!' if missing == 0 else missing}")





# Check skewness of Numeric Columns
num_cols = X_train.select_dtypes(include='number').columns.tolist()
