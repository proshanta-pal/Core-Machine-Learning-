# Detecting Outliers using IQR
def detect_outliers(train_col, test_col):
    Q1 = train_col.quantile(0.25)
    Q3 = train_col.quantile(0.75)
    IQR = Q3 - Q1

    lower_fence = Q1 - 1.5*IQR
    upper_fence = Q3 + 1.5*IQR

    # .clip() replaces values below lower with lower_fence, and above upper with upper_fence
    train_detect = train_col.clip(lower=lower_fence, upper=upper_fence)
    test_detect = test_col.clip(lower=lower_fence, upper=upper_fence)
    return train_detect, test_detect, lower_fence, upper_fence

X_train['FamilySize'], X_test['FamilySize'], low, high = (detect_outliers(X_train['FamilySize'], X_test['FamilySize']))

print("FamilySize outlier detection:")
print(f"Lower fence: {low:.2f}")
print(f"Upper fence: {high:.2f}")
print(f"Values now range from {X_train['FamilySize'].min()} to {X_train['FamilySize'].max()}")


# Final Skewness Report

num_cols = X_train.select_dtypes(include='number').columns.tolist()
final_skew = X_train[num_cols].skew().sort_values(ascending=False)

for col, skew_val in final_skew.items():
    # Classify skewness level
    if abs(skew_val) < 0.5:
        status = "Good"
    elif abs(skew_val) < 1.0:
        status = "Acceptable"
    else:
        status = "Needs attention"

    print(f"{col:<20} skew = {skew_val:>7.3f} - {status}")
